{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "install:all": "pnpm install --no-frozen-lockfile",
    "db:push": "pnpm --filter @workspace/db run push-force",
    "build": "pnpm -r --if-present run build",
    "start": "pnpm --filter @workspace/api-server run start",
    "setup": "pnpm run install:all && pnpm run db:push && pnpm run build"
  },
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  },
  "packageManager": "pnpm@9.15.4"
}
